# Django
DJANGO_SETTINGS_MODULE=config.settings.local
# Local only: set false to hide the yellow debug page (still log errors in the runserver terminal)
# DJANGO_DEBUG=false
DJANGO_SECRET_KEY=generate-a-long-random-string-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-service.onrender.com

# Production TLS / HSTS (optional)
SECURE_SSL_REDIRECT=true
ENABLE_HSTS=false
SECURE_HSTS_SECONDS=31536000

# CORS (comma-separated; required in production settings)
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# Staff / analytics — GET /api/operations/summary/ with header X-Operations-Key: <this value>
# Use a long random string; do not expose in public frontend JS (use Retool server-side or a logged-in admin later).
OPERATIONS_API_KEY=

# Data — PyMongo (no Django ORM plugin).
# Option A — full URI (password must be URL-encoded if it contains @ # & etc.):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kiwiDB?retryWrites=true&w=majority
# Option B — split vars (password can contain &; we encode automatically). Omit MONGO_URI or leave blank:
# DATABASEUSERNAME=dbuser
# DATABASEPASSWORD=your_password
# MONGO_CLUSTER_HOST=firstcluster.xxxxx.mongodb.net
# MONGO_DB_NAME=kiwiDB
# MONGO_APP_NAME=FirstCluster
# Docker Compose local (use this OR Atlas, not both):
MONGO_URI=mongodb://mongo:27017/kiwiDB

# Celery / Redis (Render: use Internal Redis URL or external provider)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Square (frontend uses REACT_APP_SQUARE_APPLICATION_ID with Vite: VITE_SQUARE_APPLICATION_ID)
REACT_APP_SQUARE_APPLICATION_ID=
# Optional override; otherwise REACT_APP_* above is used
# SQUARE_APPLICATION_ID=
# Required for Payments API + GET /api/square/config (Locations in Square Dashboard)
SQUARE_LOCATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SECRET=

# Stay dates (visitStart / visitEnd) are calendar days in this timezone (lock expires end of last day local)
BOOKING_TIMEZONE=America/Chicago
# Reject access codes when visit span (inclusive days) exceeds this (typo / abuse guard)
BOOKING_MAX_VISIT_SPAN_DAYS=90

# Seam — workspace API key (Dashboard → API Keys), not a username/password
# Docs: https://docs.seam.co/latest/api/
# After creating a PIN, poll until it is physically on the lock (status=set); tune if slow networks.
# SEAM_ACCESS_CODE_SET_TIMEOUT_SECONDS=120
# SEAM_ACCESS_CODE_POLL_INTERVAL_SECONDS=2
# Local dev only: skip polling (treat HTTP 200 as success — not for production).
# SEAM_SKIP_ACCESS_CODE_SET_POLL=false
# Kwikset: leave false so codes activate at your starts_at (true = native scheduling can delay activation several minutes).
# SEAM_PREFER_NATIVE_SCHEDULING=false
# Regenerate PIN and retry when Kwikset reports duplicate/conflict (e.g. kwikset_unable_to_confirm_code).
# SEAM_PIN_MAX_ATTEMPTS=5
SEAM_API_KEY=
# Lock UUID from Seam (preferred). Also accepts SEAM_DEVICE_ID.
# DEVICE_ID=
# Or set a display name to resolve via /devices/list (case-insensitive), e.g. the label "Grape" in the Seam UI:
# SEAM_DEVICE_NAME=Grape
# Permanent backup: Seam access_code UUIDs (Console → Access Code → id). One is chosen at random per payment (shuffle + first successful access_codes/get).
# Duplicate values are skipped. Must be access_code_id, not device_id.
# SEAM_BACKUP_CODE_1_ID=
# SEAM_BACKUP_CODE_2_ID=
# SEAM_BACKUP_CODE_3_ID=
# SEAM_BACKUP_CODE_4_ID=
# SEAM_BACKUP_CODE_5_ID=
# If all of the above fail (or SEAM_API_KEY missing), optional 6-digit static fallback:
# SEAM_BACKUP_STATIC_CODE=123456
# Label used only for static fallback when Seam name is unavailable (default KIWIBACKUPKEY):
# SEAM_BACKUP_LOCK_NAME=KIWIBACKUPKEY
# Optional; default is https://connect.getseam.com
# SEAM_API_BASE_URL=

# Email — SendGrid
SENDGRID_API_KEY=
# Dynamic Template ID (Email API → Dynamic Templates; starts with d-). Typo alias: SENDGRID_DEFUALT_TEMPLATE_ID
SENDGRID_DEFAULT_TEMPLATE_ID=
# Display name in inbox "From"
SENDGRID_FROM_NAME=Team Kiwi
# Optional: JSON merged into template Handlebars (e.g. site_url, support_phone)
# SENDGRID_TEMPLATE_EXTRA_JSON={"site_url":"https://example.com","support_email":"help@example.com"}
# Optional legacy SMTP password; ignored if SENDGRID_API_KEY is set
# EMAIL_PASS=
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_USE_TLS=true
# Must match verified sender / domain in SendGrid
DEFAULT_FROM_EMAIL=bookings@yourdomain.com
# Comma-separated — Seam / door code provisioning failed after payment (plain-text alert)
ADMIN_EMAIL_NOTIFICATIONS=micahchen@utexas.edu
